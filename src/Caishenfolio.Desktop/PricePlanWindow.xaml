<Window x:Class="Caishenfolio.Desktop.PricePlanWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="计划价位与真实成交"
        Height="640"
        Width="860"
        MinHeight="480"
        MinWidth="720"
        WindowStartupLocation="CenterOwner"
        Background="#0F1419"
        Foreground="#E7ECF1">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="计划买/卖点 · 真实成交记录" FontSize="18" FontWeight="SemiBold" />
            <TextBlock x:Name="ContextText" Margin="0,4,0,0" FontFamily="Consolas" FontSize="12" Opacity="0.9" />
            <TextBlock TextWrapping="Wrap" Opacity="0.75" FontSize="12" Margin="0,4,0,0"
                       Text="计划价位会在主图 K 线上画横线，并显示距现价的百分比与价差。真实成交单独记录用于盈亏。不连接券商、不自动下单。" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Planned levels -->
            <Border Grid.Column="0" Background="#1A222C" CornerRadius="8" Padding="12">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <TextBlock Text="计划价位（可多个）" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="50" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="PlanSideBox" Grid.Column="0" Margin="0,0,6,0" SelectedIndex="0">
                                <ComboBoxItem Content="买" Tag="buy" />
                                <ComboBoxItem Content="卖" Tag="sell" />
                            </ComboBox>
                            <TextBox x:Name="PlanPriceBox" Grid.Column="1" Padding="4" Margin="0,0,6,0" ToolTip="计划价格" />
                            <TextBlock Grid.Column="2" Text="备注" VerticalAlignment="Center" Margin="0,0,4,0" Opacity="0.8" />
                            <TextBox x:Name="PlanNoteBox" Grid.Column="3" Padding="4" />
                        </Grid>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="添加计划线" Padding="10,5" Margin="0,0,8,0" Click="AddPlan_OnClick" />
                            <Button Content="删除选中" Padding="10,5" Margin="0,0,8,0" Click="RemovePlan_OnClick" />
                            <Button Content="停用选中" Padding="10,5" Click="DeactivatePlan_OnClick" />
                        </StackPanel>
                    </StackPanel>
                    <ListBox x:Name="PlanList"
                             Background="#12181F"
                             Foreground="#E7ECF1"
                             BorderThickness="0"
                             DisplayMemberPath="Display" />
                </DockPanel>
            </Border>

            <!-- Actual fills -->
            <Border Grid.Column="2" Background="#1A222C" CornerRadius="8" Padding="12">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <TextBlock Text="真实成交记录" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="FillSideBox" Grid.Column="0" Margin="0,0,6,0" SelectedIndex="0">
                                <ComboBoxItem Content="买" Tag="buy" />
                                <ComboBoxItem Content="卖" Tag="sell" />
                            </ComboBox>
                            <TextBox x:Name="FillPriceBox" Grid.Column="1" Padding="4" Margin="0,0,6,0" ToolTip="成交价" />
                            <TextBox x:Name="FillQtyBox" Grid.Column="2" Padding="4" Margin="0,0,6,0" ToolTip="数量" />
                            <TextBox x:Name="FillFeeBox" Grid.Column="3" Padding="4" Margin="0,0,6,0" Text="0" ToolTip="费用" />
                            <TextBox x:Name="FillNoteBox" Grid.Column="4" Padding="4" ToolTip="备注" />
                        </Grid>
                        <StackPanel Orientation="Horizontal">
                            <Button Content="登记成交" Padding="10,5" Margin="0,0,8,0" Click="AddFill_OnClick" />
                            <Button Content="删除选中" Padding="10,5" Click="RemoveFill_OnClick" />
                        </StackPanel>
                    </StackPanel>
                    <ListBox x:Name="FillList"
                             Background="#12181F"
                             Foreground="#E7ECF1"
                             BorderThickness="0"
                             DisplayMemberPath="Display" />
                </DockPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#1A222C" CornerRadius="8" Padding="12" Margin="0,12,0,0">
            <TextBlock x:Name="SummaryText" FontFamily="Consolas" FontSize="12" TextWrapping="Wrap" />
        </Border>

        <DockPanel Grid.Row="3" Margin="0,12,0,0">
            <Button DockPanel.Dock="Right" Content="关闭" Padding="16,6" IsCancel="True" Click="Close_OnClick" />
            <Button DockPanel.Dock="Right" Content="刷新并同步到K线" Padding="12,6" Margin="0,0,8,0" Click="Refresh_OnClick" />
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Opacity="0.85" TextWrapping="Wrap" />
        </DockPanel>
    </Grid>
</Window>
