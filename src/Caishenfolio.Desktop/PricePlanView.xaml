<UserControl x:Class="Caishenfolio.Desktop.PricePlanView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BrushBgPanel}"
             Foreground="{StaticResource BrushFgPrimary}">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="计划买/卖点 · 真实成交" FontSize="18" FontWeight="SemiBold" />
            <TextBlock x:Name="ContextText" Margin="0,4,0,0" FontFamily="Consolas" FontSize="12" Opacity="0.9" />
            <TextBlock TextWrapping="Wrap" Foreground="{StaticResource BrushFgMuted}" FontSize="12" Margin="0,4,0,0"
                       Text="计划价位在「行情」页 K 线上画横线并显示距现价距离。真实成交用于盈亏估算。不连接券商。" />
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="12" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource BrushBgInput}" CornerRadius="8" Padding="12"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="1">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <TextBlock Text="计划价位（可多个）" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="50" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="PlanSideBox" Grid.Column="0" Margin="0,0,6,0" SelectedIndex="0">
                                <ComboBoxItem Content="买" Tag="buy" />
                                <ComboBoxItem Content="卖" Tag="sell" />
                            </ComboBox>
                            <TextBox x:Name="PlanPriceBox" Grid.Column="1" Padding="4" Margin="0,0,6,0" />
                            <TextBlock Grid.Column="2" Text="备注" VerticalAlignment="Center" Margin="0,0,4,0"
                                       Foreground="{StaticResource BrushFgMuted}" />
                            <TextBox x:Name="PlanNoteBox" Grid.Column="3" Padding="4" />
                        </Grid>
                        <WrapPanel>
                            <Button Content="添加计划线" Padding="10,5" Margin="0,0,8,6" Click="AddPlan_OnClick" />
                            <Button Content="图上点选买" Padding="10,5" Margin="0,0,8,6" Click="PickPlanBuy_OnClick" />
                            <Button Content="图上点选卖" Padding="10,5" Margin="0,0,8,6" Click="PickPlanSell_OnClick" />
                            <Button Content="删除选中" Padding="10,5" Margin="0,0,8,6" Click="RemovePlan_OnClick" />
                            <Button Content="停用选中" Padding="10,5" Margin="0,0,0,6" Click="DeactivatePlan_OnClick" />
                        </WrapPanel>
                    </StackPanel>
                    <ListBox x:Name="PlanList" DisplayMemberPath="Display" />
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Background="{StaticResource BrushBgInput}" CornerRadius="8" Padding="12"
                    BorderBrush="{StaticResource BrushBorder}" BorderThickness="1">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                        <TextBlock Text="真实成交记录" FontWeight="SemiBold" Margin="0,0,0,8" />
                        <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="60" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="FillSideBox" Grid.Column="0" Margin="0,0,6,0" SelectedIndex="0">
                                <ComboBoxItem Content="买" Tag="buy" />
                                <ComboBoxItem Content="卖" Tag="sell" />
                            </ComboBox>
                            <TextBox x:Name="FillPriceBox" Grid.Column="1" Padding="4" Margin="0,0,6,0" />
                            <TextBox x:Name="FillQtyBox" Grid.Column="2" Padding="4" Margin="0,0,6,0" ToolTip="数量" />
                            <TextBox x:Name="FillFeeBox" Grid.Column="3" Padding="4" Margin="0,0,6,0" Text="0" ToolTip="费用" />
                            <TextBox x:Name="FillNoteBox" Grid.Column="4" Padding="4" ToolTip="备注" />
                        </Grid>
                        <WrapPanel>
                            <Button Content="登记成交" Padding="10,5" Margin="0,0,8,6" Click="AddFill_OnClick" />
                            <Button Content="图上取买价" Padding="10,5" Margin="0,0,8,6" Click="PickFillBuy_OnClick" />
                            <Button Content="图上取卖价" Padding="10,5" Margin="0,0,8,6" Click="PickFillSell_OnClick" />
                            <Button Content="删除选中" Padding="10,5" Margin="0,0,0,6" Click="RemoveFill_OnClick" />
                        </WrapPanel>
                    </StackPanel>
                    <ListBox x:Name="FillList" DisplayMemberPath="Display" />
                </DockPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="{StaticResource BrushBgInput}" CornerRadius="8" Padding="12" Margin="0,12,0,0"
                BorderBrush="{StaticResource BrushBorder}" BorderThickness="1">
            <TextBlock x:Name="SummaryText" FontFamily="Consolas" FontSize="12" TextWrapping="Wrap"
                       Foreground="{StaticResource BrushFgSecondary}" />
        </Border>

        <DockPanel Grid.Row="3" Margin="0,10,0,0">
            <Button DockPanel.Dock="Right" Content="刷新并同步到K线" Padding="12,6" Click="Refresh_OnClick" />
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" TextWrapping="Wrap"
                       Foreground="{StaticResource BrushFgSecondary}" />
        </DockPanel>
    </Grid>
</UserControl>
