<UserControl x:Class="Caishenfolio.Desktop.GridView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#0F1419"
             Foreground="#E7ECF1">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="网格策略工作台" FontSize="20" FontWeight="SemiBold" />
            <TextBlock TextWrapping="Wrap" Opacity="0.8" FontSize="12" Margin="0,4,0,0"
                       Text="研究/模拟用：AI 启发式建议参数 → 历史回测 → 人工成交台账（记录盈亏与下一买卖点）。不连接券商、不自动挂单。" />
            <TextBlock x:Name="ContextText" Margin="0,6,0,0" FontFamily="Consolas" FontSize="12" Opacity="0.9" />
        </StackPanel>

        <TabControl Grid.Row="1" Background="#0F1419" BorderBrush="#2A3542">
            <!-- Suggest + Backtest -->
            <TabItem Header="建议与回测">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#1A222C" CornerRadius="8" Padding="12">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="网格参数" FontWeight="SemiBold" FontSize="14" Margin="0,0,0,10" />
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="下沿" VerticalAlignment="Center" Margin="0,0,0,8" />
                                    <TextBox x:Name="LowerBox" Grid.Row="0" Grid.Column="1" Padding="6" Margin="0,0,0,8" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="上沿" VerticalAlignment="Center" Margin="0,0,0,8" />
                                    <TextBox x:Name="UpperBox" Grid.Row="1" Grid.Column="1" Padding="6" Margin="0,0,0,8" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="网格数" VerticalAlignment="Center" Margin="0,0,0,8" />
                                    <TextBox x:Name="GridCountBox" Grid.Row="2" Grid.Column="1" Padding="6" Text="10" Margin="0,0,0,8" />

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="每格金额" VerticalAlignment="Center" Margin="0,0,0,8" />
                                    <TextBox x:Name="OrderCashBox" Grid.Row="3" Grid.Column="1" Padding="6" Text="1000" Margin="0,0,0,8" />

                                    <TextBlock Grid.Row="4" Grid.Column="0" Text="初始资金" VerticalAlignment="Center" Margin="0,0,0,8" />
                                    <TextBox x:Name="InitialCashBox" Grid.Row="4" Grid.Column="1" Padding="6" Text="" Margin="0,0,0,8"
                                             ToolTip="留空=每格金额×网格数" />

                                    <TextBlock Grid.Row="5" Grid.Column="0" Text="回看根数" VerticalAlignment="Center" Margin="0,0,0,8" />
                                    <TextBox x:Name="LookbackBox" Grid.Row="5" Grid.Column="1" Padding="6" Text="" Margin="0,0,0,8"
                                             ToolTip="建议用；留空=全部区间" />
                                </Grid>

                                <StackPanel Orientation="Vertical" Margin="0,8,0,0">
                                    <Button Content="AI 建议网格参数" Padding="10,6" Margin="0,0,0,8" Click="Suggest_OnClick" />
                                    <Button Content="运行网格回测" Padding="10,6" Margin="0,0,0,8" Click="Backtest_OnClick" />
                                    <Button Content="保存为台账方案" Padding="10,6" Click="SavePlan_OnClick" />
                                </StackPanel>

                                <TextBlock Text="档位预览" FontWeight="SemiBold" Margin="0,14,0,6" />
                                <TextBox x:Name="LevelsPreviewBox"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         Height="120"
                                         Background="#12181F"
                                         Foreground="#E7ECF1"
                                         BorderThickness="0"
                                         FontFamily="Consolas"
                                         FontSize="11"
                                         VerticalScrollBarVisibility="Auto" />
                            </StackPanel>
                        </ScrollViewer>
                    </Border>

                    <Border Grid.Column="2" Background="#1A222C" CornerRadius="8" Padding="12">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Top" Text="建议理由 / 回测摘要" FontWeight="SemiBold" Margin="0,0,0,8" />
                            <TextBox x:Name="SuggestResultBox"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     Background="#12181F"
                                     Foreground="#E7ECF1"
                                     BorderThickness="0"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     VerticalScrollBarVisibility="Auto" />
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <!-- Ledger -->
            <TabItem Header="成交台账">
                <Grid Margin="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="#1A222C" CornerRadius="8" Padding="12">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                                <TextBlock Text="已保存方案" FontWeight="SemiBold" Margin="0,0,0,6" />
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="刷新" Padding="10,4" Margin="0,0,8,0" Click="RefreshPlans_OnClick" />
                                    <Button Content="停用" Padding="10,4" Click="DeactivatePlan_OnClick" />
                                </StackPanel>
                            </StackPanel>
                            <ListBox x:Name="PlanList"
                                     Background="#12181F"
                                     Foreground="#E7ECF1"
                                     BorderThickness="0"
                                     DisplayMemberPath="Display"
                                     SelectionChanged="PlanList_OnSelectionChanged" />
                        </DockPanel>
                    </Border>

                    <Border Grid.Column="2" Background="#1A222C" CornerRadius="8" Padding="12">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="记录人工成交（非券商下单）" FontWeight="SemiBold" Margin="0,0,0,8" />
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="方向" VerticalAlignment="Center" Margin="0,0,6,6" />
                                    <ComboBox x:Name="SideBox" Grid.Row="0" Grid.Column="1" Margin="0,0,8,6" SelectedIndex="0">
                                        <ComboBoxItem Content="buy" />
                                        <ComboBoxItem Content="sell" />
                                    </ComboBox>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="价格" VerticalAlignment="Center" Margin="0,0,6,6" />
                                    <TextBox x:Name="FillPriceBox" Grid.Row="0" Grid.Column="3" Padding="4" Margin="0,0,8,6" />
                                    <TextBlock Grid.Row="0" Grid.Column="4" Text="数量" VerticalAlignment="Center" Margin="0,0,6,6" />
                                    <TextBox x:Name="FillQtyBox" Grid.Row="0" Grid.Column="5" Padding="4" Margin="0,0,0,6" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="费用" VerticalAlignment="Center" Margin="0,0,6,0" />
                                    <TextBox x:Name="FillFeeBox" Grid.Row="1" Grid.Column="1" Padding="4" Text="0" Margin="0,0,8,0" />
                                    <TextBlock Grid.Row="1" Grid.Column="2" Text="档位" VerticalAlignment="Center" Margin="0,0,6,0" />
                                    <TextBox x:Name="FillLevelBox" Grid.Row="1" Grid.Column="3" Padding="4" Margin="0,0,8,0"
                                             ToolTip="可选；买入成本档位" />
                                    <TextBlock Grid.Row="1" Grid.Column="4" Text="现价" VerticalAlignment="Center" Margin="0,0,6,0" />
                                    <TextBox x:Name="LastPriceBox" Grid.Row="1" Grid.Column="5" Padding="4"
                                             ToolTip="用于未实现盈亏与下一买卖点" />
                                </Grid>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Button Content="登记成交" Padding="12,6" Margin="0,0,8,0" Click="AddFill_OnClick" />
                                    <Button Content="刷新盈亏/下一买卖点" Padding="12,6" Click="RefreshSnapshot_OnClick" />
                                </StackPanel>

                                <TextBlock Text="盈亏与建议" FontWeight="SemiBold" Margin="0,0,0,6" />
                                <TextBox x:Name="SnapshotBox"
                                         IsReadOnly="True"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         Height="280"
                                         Background="#12181F"
                                         Foreground="#E7ECF1"
                                         BorderThickness="0"
                                         FontFamily="Consolas"
                                         FontSize="12"
                                         VerticalScrollBarVisibility="Auto" />
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>

        <DockPanel Grid.Row="2" Margin="0,10,0,0">
            <TextBlock x:Name="StatusText" VerticalAlignment="Center" Opacity="0.85" TextWrapping="Wrap" />
        </DockPanel>
    </Grid>
</UserControl>
